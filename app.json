{
  "expo": {
    "name": "COLISDAV",
    "slug": "colisdav",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/colisdav.png",
    "scheme": "cid",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.colisdav",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/colisdav.png",
        "backgroundColor": "#00000000"
      },
      "package": "app.rork.colisdav"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3f0a8c23-5645-4303-b3ff-dc5f6382cfee"
      }
    }
  }
}
