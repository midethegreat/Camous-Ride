{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "cross-env EXPO_SKIP_DEPENDENCY_VALIDATION=true EXPO_NO_DOCTOR=true EXPO_NO_TELEMETRY=true NODE_OPTIONS=--dns-result-order=ipv4first expo start",
    "start-web": "cross-env NODE_OPTIONS=--dns-result-order=ipv4first expo start --web",
    "start-web-dev": "cross-env DEBUG=expo* NODE_OPTIONS=--dns-result-order=ipv4first expo start --web",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.91.3",
    "expo": "~54.0.0",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linking": "~7.0.0",
    "expo-location": "~18.0.0",
    "expo-router": "~5.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.0",
    "lucide-react-native": "^0.475.0",
    "react": "18.3.1",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "cross-env": "^10.1.0"
  },
  "private": true
}
